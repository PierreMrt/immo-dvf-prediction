# immo-dvf-prediction - Variables d'environnement
# Chemins : toujours relatifs à la racine du projet (pas de chemins absolus)

# ============================================
# API Keys
# ============================================
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ============================================
# LLM
# ============================================
LLM_MODEL=mistralai/mistral-7b-instruct
LLM_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Configuration données
# ============================================
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
MODELS_DIR=models

# Format CSV : 2024,2025,2026  OU JSON : [2024,2025,2026]
DVF_YEARS=2024,2025,2026
CITY_CODE_INSEE=49007
DEPARTMENT_CODE=49

# ============================================
# Configuration ML
# ============================================
RANDOM_SEED=42
TEST_SIZE=0.2
DEFAULT_MODEL=xgboost

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
